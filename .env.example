# Mixpanel - Service Account (Query/Export API)
# Crear en: Mixpanel > Settings > Organization Settings > Service Accounts
MIXPANEL_SERVICE_ACCOUNT_USERNAME=
MIXPANEL_SERVICE_ACCOUNT_SECRET=
MIXPANEL_PROJECT_ID=
MIXPANEL_REGION=us

# HubSpot - Private App (Read-only)
# Crear en: HubSpot > Settings > Integrations > Private Apps
HUBSPOT_ACCESS_TOKEN=

# Meta Ads - Marketing API (opcional, solo lectura)
# Crear en: Meta Business Suite > Business Settings > System Users > Generate Token
# Permisos requeridos: ads_read
META_ADS_ACCESS_TOKEN=
META_ADS_ACCOUNT_ID=

# Google Ads API (opcional, solo lectura)
# Developer token: Google Ads > Tools > API Center
# OAuth2: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0
# Customer ID: numero de 10 digitos de la cuenta (con o sin guiones)
# Login Customer ID: solo si se accede via cuenta MCC (manager account)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# OpenAI - Whisper transcripcion de audios (opcional)
# Si se configura, los audios .oga de WhatsApp en comunicaciones
# se transcriben automaticamente a texto via Whisper API
OPENAI_API_KEY=

# Keycloak OAuth 2.1 (solo requerido en modo HTTP - TRANSPORT=http)
# Crear client en: Keycloak > Realm medicus > Clients > Create
# Tipo: OpenID Connect, Access Type: confidential, Standard Flow: enabled
KEYCLOAK_URL=https://keycloak-test.apps.medicus.com.ar
KEYCLOAK_REALM=medicus
KEYCLOAK_CLIENT_ID=autopista-mcp
KEYCLOAK_CLIENT_SECRET=

# Rol de Keycloak requerido para acceder al MCP (default: * = todos los autenticados)
KEYCLOAK_REQUIRED_ROLE=*

# URL publica donde se despliega este MCP server (HTTPS en produccion)
MCP_BASE_URL=http://localhost:3000
